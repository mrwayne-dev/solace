# IGNORE ONLY THINGS THAT SHOULD NOT BE IN GIT
# ==============================

# OS Files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Logs
logs/
api/cron/*.log
api/cron/*.txt
email_debug.log
wallet_debug.log

# Uploads
uploads/
!uploads/.gitkeep

# Private env files
config/env.php
config/test_db.php
config/certs/
*.pem
*.crt
*.key

# Composer vendor (optional)
vendor/

# node_modules (if any)
node_modules/
