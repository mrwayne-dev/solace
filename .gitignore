# =========================================================
# TitanXHoldings — .gitignore
# =========================================================

# ----- Environment / secrets -----
.env
.env.local
.env.*.local
*.env.backup

# ----- Logs -----
logs/
*.log

# ----- Editor / OS noise -----
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
*~

# ----- PHP / Composer -----
vendor/
composer.lock

# ----- Node (if added later) -----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ----- Local SQL dumps / backups -----
*.sql.bak
dbschema/local-*.sql
