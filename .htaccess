# ===============================
# Solace Mining .htaccess
# Unified Auto-Detect — Local + Production
# ===============================

<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /

# -------------------------------
# ENVIRONMENT DETECTION
# -------------------------------
# Localhost (Laragon or XAMPP)
RewriteCond %{HTTP_HOST} ^localhost [NC]
SetEnv SLM_ENV dev

# Production
RewriteCond %{HTTP_HOST} !^localhost [NC]
SetEnv SLM_ENV prod

# -------------------------------
# REDIRECT RULES (env-aware)
# -------------------------------

# Force HTTPS + non-www on production
RewriteCond %{ENV:SLM_ENV} =prod
RewriteCond %{HTTPS} !=on [OR]
RewriteCond %{HTTP_HOST} ^www\. [NC]
RewriteCond %{HTTP_HOST} ^(?:www\.)?(.*)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

# Skip HTTPS redirect in dev
RewriteCond %{ENV:SLM_ENV} =dev
RewriteRule ^ - [L]

# -------------------------------
# DO NOT rewrite static assets
# -------------------------------
RewriteCond %{REQUEST_URI} ^/assets/ [NC,OR]
RewriteCond %{REQUEST_URI} \.(css|js|png|jpg|jpeg|gif|webp|svg|ico|woff2?|ttf|eot|mp4)$ [NC]
RewriteRule ^ - [L]

# -------------------------------
# API ROUTES
# -------------------------------
RewriteCond %{REQUEST_URI} ^/api/ [NC]
RewriteRule ^api/(.*)$ api/$1 [L,QSA]

# -------------------------------
# PUBLIC ROUTES
# -------------------------------
RewriteRule ^$ pages/public/index.php [L,QSA]
RewriteRule ^contact/submit/?$ api/backend/contact.php [L,QSA]
RewriteRule ^(about|contact|login|register|forgotpassword|investment)/?$ pages/public/$1.php [L,QSA]
RewriteRule ^(privacy|terms|cookies|risk-disclosure|aml-policy)/?$ pages/public/legal.php [L,QSA]

# -------------------------------
# USER ROUTES
# -------------------------------
RewriteRule ^dashboard/?$ pages/user/dashboard.php [L,QSA]
RewriteRule ^dashboard\.(investment|referral|wallet|transactions|profile|logout)/?$ pages/user/$1.php [L,QSA]

# -------------------------------
# ADMIN ROUTES
# -------------------------------
RewriteRule ^admin/?$ pages/admin/dashboard.php [L,QSA]
RewriteRule ^admin\.(dashboard|users|wallets|transactions|announcements|funds|login|register|forgotpassword)/?$ pages/admin/$1.php [L,QSA]

# -------------------------------
# CATCH-ALL → 404
# -------------------------------
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^.*$ pages/public/error.php [L,QSA]
</IfModule>

# ===============================
# Security & Headers
# ===============================
<IfModule mod_headers.c>
Header always set X-Frame-Options "SAMEORIGIN"
Header always set X-Content-Type-Options "nosniff"
Header always set Referrer-Policy "strict-origin-when-cross-origin"
Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
# CSP keeps 'unsafe-inline' because the app relies on inline scripts AND ~36 inline
# event handlers (onclick/onerror/onload, incl. the dashboard CSS-swap). It still blocks
# injected EXTERNAL scripts, clickjacking, <base>/<object> hijacking, and form-action.
# A nonce/'strict-dynamic' upgrade (full inline-XSS protection) is blocked until those
# inline handlers are refactored to addEventListener — see security notes.
# Third-party allowlist: Smartsupp (live chat) + Google Website Translate.
# Icons (Phosphor), charts (Chart.js) and fonts are self-hosted.
Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://*.smartsupp.com https://*.smartsuppchat.com https://*.smartsuppcdn.com https://translate.google.com https://translate.googleapis.com https://translate-pa.googleapis.com https://www.gstatic.com https://www.google.com; style-src 'self' 'unsafe-inline' https://*.smartsuppcdn.com https://www.gstatic.com https://translate.googleapis.com https://fonts.googleapis.com; font-src 'self' data: https://*.smartsuppcdn.com https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://*.smartsupp.com wss://*.smartsupp.com https://*.smartsuppchat.com wss://*.smartsuppchat.com https://*.smartsuppcdn.com https://translate.googleapis.com https://translate-pa.googleapis.com https://translate.google.com https://www.gstatic.com; frame-src 'self' https://*.smartsupp.com https://*.smartsuppchat.com https://*.smartsuppcdn.com https://translate.google.com https://www.google.com; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'self'; upgrade-insecure-requests;"
# Strip the PHP version banner (info disclosure). The "Server: LiteSpeed" banner
# must be removed in the LiteSpeed admin (Server Signature = off).
Header always unset X-Powered-By
Header unset X-Powered-By
</IfModule>

# ===============================
# Caching & Index Protection
# ===============================
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType application/font-woff2 "access plus 1 year"
</IfModule>

Options -Indexes
